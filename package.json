{
	"name": "radio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"predev": "node scripts/generate-font-css.mjs",
		"dev": "vite dev",
		"prebuild": "node scripts/generate-font-css.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && simple-git-hooks",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"gen-types": "supabase gen types typescript --linked > src/lib/logic/types/database.ts",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"subset-font": "^2.5.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"wrangler": "^4.98.0"
	},
	"dependencies": {
		"@lucide/svelte": "^1.17.0",
		"@supabase/supabase-js": "^2.106.2",
		"@wterm/dom": "^0.3.0",
		"date-fns": "^4.4.0",
		"simple-git-hooks": "^2.13.1",
		"typesafe-i18n": "^5.27.1"
	},
	"simple-git-hooks": {
		"pre-commit": "sh -c 'grep -rn \"from.*/ui/\\|from.*svelte\\|localStorage\\|window\\.\" src/lib/logic/ && exit 1 || true'"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"workerd"
		]
	}
}
